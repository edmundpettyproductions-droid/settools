{
  "name": "set-tools-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write 'src/**/*.{ts,svelte,js,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte,js,css}'",
    "comment_deploy": "After editing source: npm run build, then commit the regenerated ../tomorrow/ folder. The Python server at :8282 will serve it at /tomorrow/."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4"
  }
}
