# Production materials with PII — keep off GitHub
*.pdf
*.xlsx
*.xlsm
*.xls

# Sample bibles / analysis dumps (anything in _samples is local-only)
_samples/__pycache__/
_samples/*.txt
_samples/*.csv
_samples/*.tsv

# Large installer files
*.exe
*.7z.exe

# Temp/utility files
files.zip
extract_pdfs.py
pdf_extracted.json
pdf_tmp/
files/
PortableGit/

# Claude internal
.claude/

# Node / build artifacts
node_modules/
dist/
.env
.env.local

# Svelte app build output (kept out of git; produced by `npm run build`)
app/node_modules/
app/dist/
app/.svelte-kit/

# Supabase CLI cache
backend/supabase/.temp/
backend/supabase/.branches/

# OS junk
.DS_Store
Thumbs.db
